# Supabase — obtenus depuis le dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service_role — JAMAIS côté client, uniquement Edge Functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — envoi emails phishing simulés + notifications
RESEND_API_KEY=re_xxxxxxxxxxxx

# HMAC secret pour les tokens phishing (générer avec: openssl rand -hex 32)
PHISHING_HMAC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry — monitoring erreurs
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Base URL de la plateforme (sans slash final)
NEXT_PUBLIC_APP_URL=https://cyberguard.sonabhy.bf

# URL de suivi phishing (domaine dédié, différent de l'app)
PHISHING_TRACKING_BASE_URL=https://secure-update.sonabhy-rh.com
