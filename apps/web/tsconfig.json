{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@cyberguard/db": [
        "../../packages/db/src/index.ts"
      ],
      "@cyberguard/db/*": [
        "../../packages/db/src/*"
      ],
      "@cyberguard/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@cyberguard/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
